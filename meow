-- Helper: Load function
local function loadScript(url)
    local success, message = pcall(function()
        loadstring(game:HttpGet(url, true))()
    end)
    if success then
        MainFrame.Visible = false 
        PopupFrame.Visible = false
    else
        warn("Load failed: " .. message)
    end
end

-- Helper: Animate function
local function animate(button)
    local origSize = button.Size
    local origColor = button.BackgroundColor3
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {Size = origSize + UDim2.new(0, 5, 0, 5)}):Play()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = origColor:Lerp(Color3.new(1, 1, 1), 0.1)}):Play()
    end)
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {Size = origSize}):Play()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = origColor}):Play()
    end)
end

-- Device Logic
local pcConn, mobConn
local function openDeviceSelect(gameName)
    PopupFrame.Visible = true
    if pcConn then pcConn:Disconnect() end
    if mobConn then mobConn:Disconnect() end
    
    pcConn = PCBtn.MouseButton1Click:Connect(function()
        if gameName == "Arsenal" then
            loadScript("https://raw.githubusercontent.com/eeasyxkkw-cpu/arsenalpremium/refs/heads/main/premium")
        else
            loadScript("https://raw.githubusercontent.com/eeasyxkkw-cpu/plprem/refs/heads/main/prem")
        end
    end)
    
    mobConn = MobileBtn.MouseButton1Click:Connect(function()
        if gameName == "Arsenal" then
            loadScript("https://raw.githubusercontent.com/zorluaa/ArsenalVoid/refs/heads/main/VoidArsenal")
        else
            loadScript("https://raw.githubusercontent.com/zorluaa/VoidLUAZORPRISONLIFE/refs/heads/main/NewPRISONLIFE")
        end
    end)
end

